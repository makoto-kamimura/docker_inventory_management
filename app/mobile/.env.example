# Mobile (Expo) フロントエンドの環境変数。
# `cp app/mobile/.env.example app/mobile/.env` してから必要に応じて編集する。
# EXPO_PUBLIC_* はアプリバンドルにも含まれる点に注意 (秘密を入れない)。

# Laravel API のベース URL。未設定時は http://localhost:8000 にフォールバック。
#
# - iOS シミュレータ: http://localhost:8000 で OK
# - Android エミュレータ: http://10.0.2.2:8000 (エミュ→ホストの特殊 IP)
# - 実機 (iOS/Android): PC の LAN IP (例 http://192.168.1.10:8000)
#                       + app/backend/config/cors.php の allowed_origins に追加
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
