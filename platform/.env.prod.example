# platform/.env.prod.example — 本番デプロイ用環境変数の雛形。
# `cp platform/.env.prod.example platform/.env.prod` してから値を埋める。
# 起動: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# .env.prod は **絶対に git にコミットしない** こと (`.env*` は .gitignore 済)。

# ============================================================================
# 公開ドメイン / TLS
# ============================================================================
# 公開ドメインを書くと Caddy が Let's Encrypt から TLS 証明書を自動取得する。
# DNS の A レコードがサーバ IP を指していること、80/443 がインターネットから到達可能なこと。
# まだドメインが無い場合は ":80" (HTTP のみ) で立ち上げ、後から書き換え可能。
SITE_HOSTNAME=:80
# SITE_HOSTNAME=inventory.example.com

# Let's Encrypt 用の連絡先メール (証明書失効通知などに使われる)
ACME_EMAIL=admin@example.com

# ============================================================================
# phpMyAdmin (任意 / サブドメイン運用)
# ============================================================================
# 既定の localhost:8888 だと外部にバインドされないので実質無効。
# 使うときは pma.example.com 等に変更し、DNS を別途設定する。
# PMA_HOSTNAME=pma.inventory.example.com

PMA_USER=admin
# bcrypt ハッシュを生成して貼る:
#   docker compose -f docker-compose.prod.yml run --rm proxy \
#     caddy hash-password --plaintext 'your-strong-password'
# PMA_PASSWORD_HASH=$2a$14$YourActualBcryptHashHere

# ============================================================================
# Laravel
# ============================================================================
APP_NAME=Inventory
# 一度だけ生成して固定する:
#   docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show
APP_KEY=
# クライアントから見える URL (Laravel 内部のリンク生成に使う)
APP_URL=https://inventory.example.com
LOG_LEVEL=warning

# 別オリジン公開時のみ書く (同一ドメイン運用なら空でよい)
# CORS_ALLOWED_ORIGINS=https://inventory.example.com

# ============================================================================
# データベース (compose 内部の MySQL を使う場合の既定値)
# 外部 RDS / Cloud SQL に切り替える時は DB_HOST を変更し、`db` サービスを削除する。
# ============================================================================
DB_HOST=db
DB_PORT=3306
DB_DATABASE=inventory
DB_USERNAME=user
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# ============================================================================
# Next.js (Web) ビルド時に埋め込まれる API URL
# Caddy 経由 (同一オリジン) なら空のままで OK (相対 /api/... が使われる)。
# ============================================================================
NEXT_PUBLIC_API_BASE_URL=

# ============================================================================
# 外部リバースプロキシ (Nginx / Cloudflare / 社内 LB) 配下に置く場合
# ============================================================================
# 外側の Nginx 等で TLS 終端し、HTTP で Caddy に流す構成にする時の推奨設定:
#
#   1. SITE_HOSTNAME を ":80" に固定 (Caddy 側で ACME を走らせない)
#   2. docker-compose.prod.yml の proxy.ports から "443:443" 系を削除
#      (もしくは 127.0.0.1:80:80 のように localhost バインドへ絞る)
#   3. Caddyfile の trusted_proxies は private_ranges 既定で OK。
#      Nginx が公的 IP の別ホストなら Caddyfile を編集して
#      `trusted_proxies static <nginx-ip>/32` に切り替える
#   4. Nginx 側で必ず以下のヘッダを透過:
#        proxy_set_header Host              $host;        # PMA サブドメイン分岐用
#        proxy_set_header X-Forwarded-Proto $scheme;     # Laravel が https を認識するため
#        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
#        proxy_set_header Upgrade           $http_upgrade;   # Next.js RSC / WebSocket
#        proxy_set_header Connection        "upgrade";
#
# 詳細手順は doc/operation.md §8.9 を参照。
