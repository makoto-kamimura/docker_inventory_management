# platform/docker-compose.yml が読み込む環境変数。
# `cp platform/.env.example platform/.env` してから必要に応じて編集する。
# .env は .gitignore 済 (公開リポジトリに値が漏れることはない)。

# --- MySQL ---
# 開発用デフォルト。本番では必ず差し替えること。
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=inventory
MYSQL_USER=user
MYSQL_PASSWORD=password

# --- マイグレーション挙動 ---
# migrate (default, データ保持) / fresh (drop → migrate:fresh --seed)
MIGRATE_MODE=migrate

# --- Web (Next.js) 起動モード ---
# production (default, next build + next start) / dev (next dev で HMR)
WEB_MODE=production

# ブラウザが Laravel API を叩く URL。LAN 越し / リバプロ越しなら差し替え。
# ※ NEXT_PUBLIC_* は client バンドルに埋め込まれる (秘密を入れない)。
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Alexa スキルサーバー ---
# API_BASE_URL: docker 内部から app サービスを叩く URL (dev は http://app:8000)
API_BASE_URL=http://inventory.example.com:8000
API_TOKEN=
